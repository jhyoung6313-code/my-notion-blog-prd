# Notion 연동 환경 변수 — 이 파일을 복사해 `.env.local`로 만들고 실제 값을 채운다.
# 주의: 실제 키가 든 .env.local 은 절대 커밋하지 않는다 (.gitignore 에 포함됨).

# Notion Integration Token (https://www.notion.so/my-integrations 에서 발급)
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 블로그 글 데이터베이스 ID (DB URL 의 32자리 16진수)
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
